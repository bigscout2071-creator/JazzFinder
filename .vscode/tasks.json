{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "JazzFinder: Start Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*?Error.*?$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*ready.*$",
          "endsPattern": "^.*compiled.*$"
        }
      }
    },
    {
      "label": "JazzFinder: Build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "group": {
        "kind": "build"
      },
      "problemMatcher": ["$tsc"]
    }
  ]
}
